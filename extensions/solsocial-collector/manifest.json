{
  "manifest_version": 3,
  "name": "SolSocial Collector",
  "version": "0.4.0",
  "description": "DOM-only capture of LinkedIn & Twitter/X content into TennetCTL. No platform API calls.",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "http://localhost:51734/*",
    "https://*.tennetctl.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": [
        "lib/scanner.js",
        "lib/extractors/linkedin.js",
        "lib/signals.js",
        "content/linkedin.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": [
        "lib/scanner.js",
        "lib/extractors/twitter.js",
        "lib/signals.js",
        "content/twitter.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SolSocial Collector"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
