{
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "mcpServers": {
    "playwright": {
      "command": "/opt/homebrew/bin/npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ],
      "type": "stdio"
    },
    "code-review-graph": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--with",
        "sentence-transformers",
        "code-review-graph",
        "serve"
      ],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "type": "stdio"
    },
    "context-mode": {
      "command": "npx",
      "args": [
        "-y",
        "context-mode"
      ],
      "type": "stdio"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f graphify-out/graph.json ] && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"graphify: Knowledge graph exists. Read graphify-out/GRAPH_REPORT.md for god nodes and community structure before searching raw files.\"}}' || true"
          }
        ]
      }
    ]
  }
}