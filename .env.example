# TennetCTL v2 — Environment Variables
# Copy to .env and adjust as needed: cp .env.example .env
#
# Allowed TENNETCTL_* variables (ADR-028 — vault foundation):
#   TENNETCTL_VAULT_ROOT_KEY
#   TENNETCTL_MODULES
#   TENNETCTL_SINGLE_TENANT
#   TENNETCTL_APP_PORT
#   TENNETCTL_ALLOW_UNAUTHENTICATED_VAULT
#
# Any other TENNETCTL_* variable matching *_SECRET|*_TOKEN|*_PASSWORD|*_KEY
# will BLOCK startup. Put those in the vault instead:
#   POST /v1/vault {"key": "...", "value": "..."}

# Postgres
POSTGRES_PASSWORD=tennetctl_dev
DATABASE_URL=postgresql://tennetctl:tennetctl_dev@localhost:5434/tennetctl

# Test database (used by pytest)
TEST_DATABASE_URL=postgresql://tennetctl:tennetctl_dev@localhost:5434/tennetctl_test

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=tennetctl
MINIO_PASSWORD=tennetctl_dev

# Vault root key — 32 raw bytes base64-encoded (44 chars).
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
# ONCE set, DO NOT change without re-wrapping every secret (not supported in v0.2).
TENNETCTL_VAULT_ROOT_KEY=

# Module gating
TENNETCTL_MODULES=core,iam,audit,featureflags,vault
TENNETCTL_SINGLE_TENANT=true

# v0.2 only — lets vault routes serve without auth until phase 8 ships.
# Remove after phase 8.
TENNETCTL_ALLOW_UNAUTHENTICATED_VAULT=true

# App
APP_PORT=51734
