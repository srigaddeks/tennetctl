# SolSocial env — only non-secret runtime config. Secrets live in tennetctl vault.

# DB for solsocial business data. Uses the same Postgres server as tennetctl
# but a separate database (`solsocial`). Migrator creates it on first run.
DATABASE_URL=postgresql://tennetctl:tennetctl_dev@localhost:5434/solsocial

# Where tennetctl is reachable (solsocial proxies auth/audit/notify/vault/flags there).
SOLSOCIAL_TENNETCTL_URL=http://localhost:51734

# Path to a file containing the solsocial service API key from tennetctl
# (format: "nk_<key_id>.<secret>", from POST /v1/api-keys). The file path is
# stored here; the key itself never sits in an env var (ADR-028 blocks *API_KEY*).
# The key must carry scopes: iam:applications:read, iam:roles:*, flags:*,
# notify:send, audit:write, vault:write.
SOLSOCIAL_TENNETCTL_KEY_FILE=./secrets/tennetctl.key

# Frontend origin (CORS).
SOLSOCIAL_FRONTEND_ORIGIN=http://localhost:51835

# Publisher mode: "stub" (no real provider calls) or "live".
SOLSOCIAL_PUBLISHER_MODE=stub

SOLSOCIAL_APP_PORT=51834

# Tennetctl application binding. Every outbound call from solsocial to
# tennetctl stamps this `application_id` (resolved from the code at startup).
SOLSOCIAL_APPLICATION_CODE=solsocial
SOLSOCIAL_TENNETCTL_ORG_ID=<tennetctl-org-uuid>   # which org owns the solsocial application row

# Provider OAuth credentials — file paths only, never the secret itself (ADR-028).
# Leave any of these unset to run that provider in stub mode.
# LinkedIn: https://developer.linkedin.com/ → My Apps → create app → request
# "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn" products.
# Add redirect URL: http://localhost:51835/oauth/callback/linkedin
SOLSOCIAL_LINKEDIN_CLIENT_ID_FILE=./apps/solsocial/backend/secrets/linkedin_client_id
SOLSOCIAL_LINKEDIN_CLIENT_SECRET_FILE=./apps/solsocial/backend/secrets/linkedin_client_secret
