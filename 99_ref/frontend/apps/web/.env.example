# ─── Backend API ────────────────────────────────────────────────────────────────
# URL of the K-Control backend API.
# In Kubernetes: http://kcontrol-api:8000 (internal service name)
# In local dev:  http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Application ────────────────────────────────────────────────────────────────
# Public URL of this frontend (used for OAuth redirects, links in emails, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Environment ───────────────────────────────────────────────────────────────
# Which environment this frontend is running in.
# Controls which feature flags are active (dev/staging/prod).
# Values: "development" | "staging" | "production"
NEXT_PUBLIC_APP_ENV=development

# ─── Feature Flags (optional) ───────────────────────────────────────────────────
# Disable OAuth social login buttons if the backend doesn't support them yet.
# Values: "true" | "false"
NEXT_PUBLIC_OAUTH_ENABLED=false

# ─── Notes on Token Security ────────────────────────────────────────────────────
# Access tokens are stored in JS module memory only (never localStorage/cookies).
# Refresh tokens are stored in an httpOnly, SameSite=Strict cookie named
# "kc_refresh", set by the Next.js route handler at /api/auth/set-refresh.
# This means refresh tokens are invisible to JavaScript and immune to XSS theft.
# In production, ensure NODE_ENV=production so the Secure flag is set on the cookie.
