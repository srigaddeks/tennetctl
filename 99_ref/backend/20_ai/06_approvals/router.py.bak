from __future__ import annotations
from importlib import import_module
from typing import Annotated
from fastapi import Depends, Query

_telemetry_module = import_module("backend.01_core.telemetry")
_auth_module = import_module("backend.03_auth_manage.dependencies")
_service_module = import_module("backend.20_ai.06_approvals.service")
_schemas_module = import_module("backend.20_ai.06_approvals.schemas")
_deps_module = import_module("backend.20_ai.06_approvals.dependencies")

InstrumentedAPIRouter = _telemetry_module.InstrumentedAPIRouter
get_current_access_claims = _auth_module.get_current_access_claims
ApprovalService = _service_module.ApprovalService
ApprovalListResponse = _schemas_module.ApprovalListResponse
ApprovalResponse = _schemas_module.ApprovalResponse
RejectRequest = _schemas_module.RejectRequest
get_approval_service = _deps_module.get_approval_service

router = InstrumentedAPIRouter(prefix="/api/v1/ai/approvals", tags=["ai-approvals"])

@router.get("", response_model=ApprovalListResponse)
async def list_approvals(service: Annotated[ApprovalService, Depends(get_approval_service)],
        claims: Annotated[dict, Depends(get_current_access_claims)],
        status_code: str | None = Query(None),
        limit: int = Query(default=50, ge=1, le=200),
        offset: int = Query(default=0, ge=0)) -> ApprovalListResponse:
    return await service.list_approvals(caller_id=claims["sub"],
        tenant_key=claims.get("tenant_key","__platform__"),
        status_code=status_code, limit=limit, offset=offset)

@router.get("/{approval_id}", response_model=ApprovalResponse)
async def get_approval(approval_id: str,
        service: Annotated[ApprovalService, Depends(get_approval_service)],
        claims: Annotated[dict, Depends(get_current_access_claims)]) -> ApprovalResponse:
    return await service.get_approval(approval_id=approval_id,
        tenant_key=claims.get("tenant_key","__platform__"), caller_id=claims["sub"])

@router.post("/{approval_id}/approve", response_model=ApprovalResponse)
async def approve(approval_id: str,
        service: Annotated[ApprovalService, Depends(get_approval_service)],
        claims: Annotated[dict, Depends(get_current_access_claims)]) -> ApprovalResponse:
    return await service.approve(approval_id=approval_id,
        tenant_key=claims.get("tenant_key","__platform__"), caller_id=claims["sub"])

@router.post("/{approval_id}/reject", response_model=ApprovalResponse)
async def reject(approval_id: str, request: RejectRequest,
        service: Annotated[ApprovalService, Depends(get_approval_service)],
        claims: Annotated[dict, Depends(get_current_access_claims)]) -> ApprovalResponse:
    return await service.reject(approval_id=approval_id,
        tenant_key=claims.get("tenant_key","__platform__"),
        caller_id=claims["sub"], reason=request.reason)
