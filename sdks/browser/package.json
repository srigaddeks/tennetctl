{
  "name": "@tennetctl/browser",
  "version": "0.5.0",
  "description": "TennetCTL browser SDK for Product Ops — anonymous-first event tracking, UTM attribution, identify/alias. Zero deps, ≤5kb gzip target.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --target=es2018 --minify --outfile=dist/index.js && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
